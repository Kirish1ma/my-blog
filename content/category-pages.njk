---js
const pagination = {
	data: "collections.categoryList",
	size: 1,
	alias: "categoryKey",
};

const eleventyExcludeFromCollections = true;

const eleventyComputed = {
	title: function (data) {
		return `Category '${data.categoryKey.replace(/^cat-/, "")}'`;
	},
	permalink: function (data) {
		return `/category/${this.slugify(data.categoryKey.replace(/^cat-/, ""))}/`;
	},
};
---
<div class="container">
<div class="row">
<div class="col-md-7 p-3 p-md-5 mx-auto">
<header class="text-center mb-5">
<h1 class="display-4 header-title">Category “{{ categoryKey | categoryNameFromTag }}”</h1>
</header>
{% set postslist = collections[ categoryKey ] %}
{% include "postslist.njk" %}
<div class="border-top row p-3">
<p class="text-center p-3">
<a href="/blog" class="btn btn-dark btn-lg rounded-pill col-12 col-md-5 p-3 shadow">Explore all Post</a>
</p>
</div>
</div>
</div>
